/* ============================================================
   J·LIFT AI-GYM Prototype — Mock Store & State Management
   ============================================================
   Single source of truth for all prototype data.
   Pages subscribe via store.subscribe(fn) and re-render on change.
   ============================================================ */

const JLStore = (() => {
  // ---- Helpers ----
  const uid = () => Math.random().toString(36).slice(2, 10);
  const todayStr = () => {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  };
  const daysAgo = (n) => {
    const d = new Date();
    d.setDate(d.getDate() - n);
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  };
  const fmtTime = (sec) => {
    const m = Math.floor(sec / 60);
    const s = sec % 60;
    return `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  };
  const fmtDurationLong = (sec) => {
    const h = Math.floor(sec / 3600);
    const m = Math.floor((sec % 3600) / 60);
    if (h > 0) return `${h} 小时 ${m} 分钟`;
    return `${m} 分钟`;
  };

  // ---- Initial State ----
  const state = {
    // User profile
    profile: {
      gender: 'male',       // male / female
      age: 28,
      weight: 72,           // kg
      height: 178,          // cm
      restingHr: 62,        // bpm
      periodEnabled: false,
    },

    // Huawei Health connection
    huawei: {
      connected: true,
      lastSync: '2026-07-15 22:14',
      syncState: 'idle',    // idle / syncing / success / failure / offline / unauthorized
      authorizedScopes: ['exercise', 'weight', 'bodyFat', 'restingHeartRate'],
    },

    // Heart rate monitor
    hrm: {
      connected: false,
      deviceName: '',
      battery: 0,
      lastBpm: 0,
      status: 'idle',        // idle / scanning / connecting / connected / disconnected / failure / timeout
      connectionLost: false,
      userDisconnected: false,
      retryCount: 0,
      returnTo: null,        // 'live' for returning to training countdown
    },

    // Voice settings
    voice: {
      enabled: true,
      commandEnabled: true,
      ttsEnabled: true,
      volume: 70,           // 0-100
      // runtime state
      listening: false,
      recognizing: false,
      lastText: '',
    },

    // Exercise library
    exercises: [
      { id: 'bp', name: '杠铃卧推', category: 'chest', met: 6.0, custom: false },
      { id: 'squat', name: '杠铃深蹲', category: 'legs', met: 6.5, custom: false },
      { id: 'dl', name: '硬拉', category: 'back', met: 7.0, custom: false },
      { id: 'ohp', name: '站姿推举', category: 'shoulder', met: 5.0, custom: false },
      { id: 'row', name: '杠铃划船', category: 'back', met: 5.5, custom: false },
      { id: 'pullup', name: '引体向上', category: 'back', met: 7.5, custom: false },
      { id: 'dips', name: '双杠臂屈伸', category: 'chest', met: 6.5, custom: false },
      { id: 'curl', name: '杠铃弯举', category: 'arms', met: 4.0, custom: false },
      { id: 'running', name: '跑步', category: 'cardio', met: 8.5, custom: false, cardio: true },
      { id: 'cycling', name: '骑行', category: 'cardio', met: 6.0, custom: false, cardio: true },
    ],
    exerciseCategories: [
      { id: 'all', name: '全部' },
      { id: 'chest', name: '胸部' },
      { id: 'back', name: '背部' },
      { id: 'legs', name: '腿部' },
      { id: 'shoulder', name: '肩部' },
      { id: 'arms', name: '手臂' },
      { id: 'core', name: '核心' },
      { id: 'cardio', name: '有氧' },
    ],

    // Training records — mixed sources to validate rules
    records: [
      {
        id: 'rec-001',
        date: todayStr(),
        startTime: '07:30',
        duration: 2740,
        dataSource: 'app',          // app / huawei
        activityType: 'strength',   // strength / cardio / mixed
        calories: 312,
        calorieSource: 'hr',        // hr / met / huawei
        avgHr: 128,
        maxHr: 156,
        title: '胸部训练',
        actions: [
          { id: 'bp', name: '杠铃卧推', sets: [
            { reps: 10, weight: 60 }, { reps: 10, weight: 60 },
            { reps: 8, weight: 65 }, { reps: 6, weight: 70 },
          ]},
          { id: 'dips', name: '双杠臂屈伸', sets: [
            { reps: 12, weight: 0 }, { reps: 10, weight: 0 }, { reps: 8, weight: 0 },
          ]},
        ],
        hrCurve: [72, 88, 105, 120, 135, 142, 138, 145, 138, 128, 115, 98],
      },
      {
        id: 'rec-002',
        date: daysAgo(1),
        startTime: '18:20',
        duration: 2100,
        dataSource: 'huawei',
        activityType: 'cardio',
        calories: 285,
        calorieSource: 'huawei',
        avgHr: 142,
        maxHr: 172,
        title: '户外跑步',
        distance: 5.2,
        pace: '6\'43"',
        actions: [],
        hrCurve: [85, 110, 135, 155, 168, 172, 165, 158, 150, 140, 125, 105],
      },
      {
        id: 'rec-003',
        date: daysAgo(2),
        startTime: '08:00',
        duration: 3120,
        dataSource: 'huawei',
        activityType: 'strength',
        calories: 298,
        calorieSource: 'huawei',
        avgHr: 118,
        maxHr: 145,
        title: '腿部训练',
        actions: [
          { id: 'squat', name: '杠铃深蹲', sets: [
            { reps: 8, weight: 80 }, { reps: 8, weight: 80 }, { reps: 6, weight: 90 },
          ]},
          { id: 'dl', name: '硬拉', sets: [
            { reps: 5, weight: 100 }, { reps: 5, weight: 100 },
          ]},
        ],
        hrCurve: [70, 95, 115, 130, 140, 145, 138, 132, 125, 118, 105, 88],
      },
      {
        id: 'rec-004',
        date: daysAgo(3),
        startTime: '19:15',
        duration: 2460,
        dataSource: 'app',
        activityType: 'strength',
        calories: 268,
        calorieSource: 'met',
        avgHr: 0,
        maxHr: 0,
        title: '背部训练',
        actions: [
          { id: 'row', name: '杠铃划船', sets: [
            { reps: 10, weight: 55 }, { reps: 10, weight: 55 }, { reps: 8, weight: 60 },
          ]},
          { id: 'pullup', name: '引体向上', sets: [
            { reps: 8, weight: 0 }, { reps: 6, weight: 0 }, { reps: 5, weight: 0 },
          ]},
        ],
        hrCurve: [],
      },
      {
        id: 'rec-005',
        date: daysAgo(4),
        startTime: '07:45',
        duration: 1800,
        dataSource: 'app',
        activityType: 'cardio',
        calories: 210,
        calorieSource: 'hr',
        avgHr: 135,
        maxHr: 160,
        title: '骑行',
        distance: 12.5,
        actions: [],
        hrCurve: [80, 105, 130, 148, 160, 155, 150, 142, 135, 128, 115, 95],
      },
    ],

    // Body metrics — all measurement types with history
    bodyMetrics: {
      weight: [
        { date: daysAgo(0), value: 72.3, source: 'manual' },
        { date: daysAgo(3), value: 72.8, source: 'huawei' },
        { date: daysAgo(7), value: 73.1, source: 'huawei' },
        { date: daysAgo(10), value: 73.5, source: 'manual' },
        { date: daysAgo(14), value: 74.0, source: 'huawei' },
        { date: daysAgo(20), value: 74.2, source: 'manual' },
        { date: daysAgo(25), value: 74.5, source: 'huawei' },
      ],
      bodyFat: [
        { date: daysAgo(3), value: 18.5, source: 'huawei' },
        { date: daysAgo(10), value: 19.0, source: 'huawei' },
        { date: daysAgo(17), value: 19.3, source: 'manual' },
        { date: daysAgo(25), value: 19.8, source: 'huawei' },
      ],
      waist: [
        { date: daysAgo(0), value: 82.5, source: 'manual' },
        { date: daysAgo(7), value: 83.0, source: 'manual' },
        { date: daysAgo(14), value: 84.0, source: 'manual' },
        { date: daysAgo(21), value: 84.5, source: 'manual' },
        { date: daysAgo(28), value: 85.0, source: 'manual' },
      ],
      navelWaist: [
        { date: daysAgo(0), value: 84.0, source: 'manual' },
        { date: daysAgo(7), value: 84.8, source: 'manual' },
        { date: daysAgo(14), value: 85.5, source: 'manual' },
        { date: daysAgo(28), value: 86.5, source: 'manual' },
      ],
      hip: [
        { date: daysAgo(0), value: 98.0, source: 'manual' },
        { date: daysAgo(7), value: 98.5, source: 'manual' },
        { date: daysAgo(14), value: 99.0, source: 'manual' },
        { date: daysAgo(28), value: 99.5, source: 'manual' },
      ],
      arm: [
        { date: daysAgo(0), value: 35.5, source: 'manual' },
        { date: daysAgo(7), value: 35.2, source: 'manual' },
        { date: daysAgo(14), value: 35.0, source: 'manual' },
        { date: daysAgo(28), value: 34.8, source: 'manual' },
      ],
      thigh: [
        { date: daysAgo(0), value: 58.0, source: 'manual' },
        { date: daysAgo(7), value: 58.5, source: 'manual' },
        { date: daysAgo(14), value: 59.0, source: 'manual' },
        { date: daysAgo(28), value: 59.5, source: 'manual' },
      ],
      restingHr: [
        { date: daysAgo(0), value: 62, source: 'huawei' },
        { date: daysAgo(1), value: 63, source: 'huawei' },
        { date: daysAgo(2), value: 61, source: 'huawei' },
        { date: daysAgo(3), value: 64, source: 'huawei' },
        { date: daysAgo(7), value: 65, source: 'huawei' },
        { date: daysAgo(14), value: 66, source: 'huawei' },
      ],
    },

    // Current live training session (null when not active)
    liveSession: null,

    // First-run flags
    firstRun: {
      micPermissionGranted: true,  // simulate already granted
      shownOnboarding: false,
    },

    // Navigation
    currentPage: 'home',
    currentMetricTab: 'weight',
    currentRecordFilter: 'all',
    currentRecordId: null,
    currentExerciseCat: 'all',
    currentDeviceTab: 'hrm',

    // Overlays
    overlay: null,  // null / { type: 'sheet'|'dialog', ...props }

    // Toast
    toast: null,
  };

  // ---- Subscribers ----
  const subscribers = new Set();
  const notify = () => subscribers.forEach(fn => {
    try { fn(state); } catch (e) { console.error('Subscriber error:', e); }
  });

  // ---- Computed helpers ----
  const getLatest = (metric) => {
    const arr = state.bodyMetrics[metric];
    return arr && arr.length > 0 ? arr[0] : null;
  };

  const getBMI = () => {
    const w = getLatest('weight');
    if (!w || !state.profile.height) return null;
    return +(w.value / ((state.profile.height / 100) ** 2)).toFixed(1);
  };

  // PRD §8.4 当日重叠去重: 同一训练被 App+心率带 与 华为 同时记录时只计一次。
  // 按 date 分桶，桶内按时间重叠合并，重叠组取 calories 较大者，非重叠各自计入。
  const dedupeOverlapping = (day) => {
    const sorted = [...day].sort((a, b) => (a.date + a.startTime).localeCompare(b.date + b.startTime));
    const merged = [];
    for (const r of sorted) {
      const s = r.date + 'T' + r.startTime;
      const e = new Date(new Date(s).getTime() + r.duration * 1000);
      const hit = merged.find(m => {
        const ms = m.date + 'T' + m.startTime;
        const me = new Date(new Date(ms).getTime() + m.duration * 1000);
        return new Date(s) < me && new Date(ms) < e;
      });
      if (hit) { if (r.calories > hit.calories) hit.calories = r.calories; }
      else merged.push({ ...r });
    }
    return merged;
  };
  const getWeeklyCalories = () => {
    // PRD §8.4 当日重叠去重聚合 (见 dedupeOverlapping)
    const cutoff = daysAgo(6);
    const inWeek = state.records.filter(r => r.date >= cutoff);
    const byDay = {};
    inWeek.forEach(r => { (byDay[r.date] = byDay[r.date] || []).push(r); });
    let total = 0;
    Object.values(byDay).forEach(day => {
      dedupeOverlapping(day).forEach(r => { total += r.calories; });
    });
    return total;
  };

  const getWeeklyGoal = () => 2500; // kcal

  const getFilteredRecords = () => {
    let list = [...state.records];
    if (state.currentRecordFilter === 'cardio') {
      list = list.filter(r => r.activityType === 'cardio');
    } else if (state.currentRecordFilter === 'strength') {
      list = list.filter(r => r.activityType === 'strength');
    } else if (state.currentRecordFilter === 'mixed') {
      list = list.filter(r => r.activityType === 'mixed');
    }
    return list.sort((a, b) => (b.date + b.startTime).localeCompare(a.date + a.startTime));
  };

  const getLastRecord = () => state.records[0] || null;

  // ---- Mutations ----

  // Profile
  function updateProfile(patch) {
    Object.assign(state.profile, patch);
    notify();
  }

  // Huawei
  function setSyncState(s) {
    state.huawei.syncState = s;
    notify();
  }
  function toggleHuaweiConnection() {
    state.huawei.connected = !state.huawei.connected;
    if (state.huawei.connected) {
      state.huawei.lastSync = new Date().toLocaleString('zh-CN', { hour12: false }).slice(0, 16).replace('/', '-').replace('/', '-');
      setSyncState('idle');
    } else {
      state.huawei.syncState = 'offline';
      setSyncState('offline');
    }
    notify();
  }
  // P1-05: 同步状态机需 6 态全部可达 (idle/syncing/success/failure/offline/unauthorized)
  function triggerSync() {
    if (!state.huawei.connected) { setSyncState('offline'); return; }
    setSyncState('syncing');
    const fail = Math.random() < 0.3; // 原型演示: ~30% 失败，用于演示 failure 态
    setTimeout(() => {
      if (fail) {
        setSyncState('failure');
        setTimeout(() => setSyncState(state.huawei.connected ? 'idle' : 'offline'), 2500);
      } else {
        setSyncState('success');
        state.huawei.lastSync = new Date().toLocaleString('zh-CN', { hour12: false }).slice(0, 16).replace('/', '-').replace('/', '-');
        setTimeout(() => setSyncState(state.huawei.connected ? 'idle' : 'offline'), 2000);
      }
    }, 1800);
  }
  function simulateUnauthorized() {
    setSyncState('unauthorized');
  }

  // HRM Connection State Machine
  function scanHRM() {
    state.hrm.status = 'scanning';
    state.hrm.userDisconnected = false;
    notify();
  }
  function connectHRM(deviceName) {
    state.hrm.status = 'connecting';
    state.hrm.deviceName = deviceName;
    state.hrm.retryCount = 0;
    notify();

    const simulateSuccess = Math.random() > 0.3;
    const delay = simulateSuccess ? 1500 + Math.random() * 1000 : 3000;

    setTimeout(() => {
      if (state.hrm.status !== 'connecting') return;
      if (simulateSuccess) {
        state.hrm.status = 'connected';
        state.hrm.connected = true;
        state.hrm.battery = 70 + Math.floor(Math.random() * 25);
        state.hrm.lastBpm = 65 + Math.floor(Math.random() * 15);
        notify();
        if (!state._hrmTimer) {
          state._hrmTimer = setInterval(() => {
            if (state.hrm.connected && !state.hrm.connectionLost) {
              const base = state.liveSession ? 120 : 70;
              state.hrm.lastBpm = base + Math.floor(Math.random() * 20 - 10);
              notify();
            }
          }, 1500);
        }
      } else {
        state.hrm.status = 'failure';
        notify();
      }
    }, delay);
  }
  function disconnectHRM(userInitiated = true) {
    state.hrm.connected = false;
    state.hrm.status = 'disconnected';
    state.hrm.userDisconnected = userInitiated;
    state.hrm.connectionLost = !userInitiated;
    state.hrm.lastBpm = 0;
    if (state._hrmTimer) {
      clearInterval(state._hrmTimer);
      state._hrmTimer = null;
    }
    notify();
  }
  function startReconnect() {
    if (state.hrm.userDisconnected) return;
    state.hrm.retryCount++;
    state.hrm.status = 'connecting';
    notify();
    setTimeout(() => {
      if (state.hrm.status !== 'connecting') return;
      if (state.hrm.retryCount >= 3) {
        state.hrm.status = 'timeout';
        state.hrm.connectionLost = true;
        notify();
      } else {
        const success = Math.random() > 0.2;
        if (success) {
          state.hrm.status = 'connected';
          state.hrm.connected = true;
          state.hrm.lastBpm = 65 + Math.floor(Math.random() * 15);
          notify();
        } else {
          startReconnect();
        }
      }
    }, 2000);
  }
  function setHRMReturnTo(page) {
    state.hrm.returnTo = page;
  }
  function clearHRMReturnTo() {
    state.hrm.returnTo = null;
  }

  // Voice
  function toggleVoice() {
    state.voice.enabled = !state.voice.enabled;
    if (!state.voice.enabled) {
      state.voice.listening = false;
      state.voice.recognizing = false;
    }
    notify();
  }
  function setVoiceVolume(v) {
    state.voice.volume = v;
    notify();
  }
  function toggleVoiceCommand() {
    state.voice.commandEnabled = !state.voice.commandEnabled;
    notify();
  }
  function toggleVoiceTTS() {
    state.voice.ttsEnabled = !state.voice.ttsEnabled;
    notify();
  }
  // 语音意图 mock — 覆盖 PRD v1.2 的 7 类意图 (record/switch_action/switch_set/add_action/pause/resume/end)
  // 端侧 NLU 为原型占位；此处用预置语句表表演示各意图可达路径，真实实现须接入端侧语音识别
  const VOICE_PRESETS = [
    { text: '卧推 10 次 60 公斤', intent: 'record' },
    { text: '切换 深蹲', intent: 'switch_action' },
    { text: '加 硬拉', intent: 'add_action' },
    { text: '第 2 组', intent: 'switch_set' },
    { text: '暂停', intent: 'pause' },
    { text: '继续', intent: 'resume' },
    { text: '结束训练', intent: 'end' },
  ];
  let _voiceDemoIdx = 0;
  function resolveExercise(nameOrId) {
    if (!nameOrId) return null;
    const n = nameOrId.trim().toLowerCase();
    return state.exercises.find(e => e.id === n || e.name.trim().toLowerCase() === n)
      || state.exercises.find(e => e.name.trim().toLowerCase().includes(n));
  }
  function processVoiceCommand(text) {
    if (!text || !state.liveSession) return;
    const t = text.trim();
    const rm = t.match(/^(.+?)\s*(\d+)\s*次\s*(\d+)?\s*公斤?/);
    if (rm) {
      const ex = resolveExercise(rm[1]);
      if (ex) { setCurrentAction(ex.id); recordSet(ex.id, rm[2], rm[3] || 0); }
      return;
    }
    if (/^切换\s*(.+)/.test(t)) {
      const ex = resolveExercise(t.replace(/^切换\s*/, ''));
      if (ex) setCurrentAction(ex.id);
      return;
    }
    if (/^加\s*(.+)/.test(t)) {
      const ex = resolveExercise(t.replace(/^加\s*/, ''));
      if (ex) setCurrentAction(ex.id);
      return;
    }
    if (/^第?\s*(\d+)\s*组/.test(t)) {
      const idx = parseInt(t.match(/(\d+)/)[1], 10) - 1;
      state.liveSession.currentSetIndex = Math.max(0, idx);
      return;
    }
    if (t === '暂停' || t === '暂停训练') { if (!state.liveSession.paused) togglePause(); return; }
    if (t === '继续' || t === '继续训练') { if (state.liveSession.paused) togglePause(); return; }
    if (t === '结束' || t === '结束训练') { endLiveSession(); return; }
  }
  function startListening() {
    if (!state.voice.enabled || !state.voice.commandEnabled) return;
    state.voice.listening = true;
    state.voice.recognizing = false;
    notify();
    setTimeout(() => {
      state.voice.recognizing = true;
      state.voice.listening = false;
      notify();
      setTimeout(() => {
        state.voice.recognizing = false;
        const preset = VOICE_PRESETS[_voiceDemoIdx % VOICE_PRESETS.length];
        _voiceDemoIdx++;
        state.voice.lastText = preset.text;
        if (state.liveSession) processVoiceCommand(preset.text);
        notify();
        setTimeout(() => { state.voice.lastText = ''; notify(); }, 2500);
      }, 1200);
    }, 1500);
  }
  function stopListening() {
    state.voice.listening = false;
    state.voice.recognizing = false;
    notify();
  }

  // Navigation
  function go(page, params = {}) {
    state.currentPage = page;
    if (params.recordId) state.currentRecordId = params.recordId;
    state.overlay = null;
    notify();
    // Scroll to top
    const scroller = document.querySelector('.jl-phone__content, .jl-tablet__content');
    if (scroller) scroller.scrollTop = 0;
  }
  function setMetricTab(tab) {
    state.currentMetricTab = tab;
    notify();
  }
  function setRecordFilter(f) {
    state.currentRecordFilter = f;
    notify();
  }
  function setExerciseCat(c) {
    state.currentExerciseCat = c;
    notify();
  }

  // Overlays
  function openOverlay(o) {
    state.overlay = o;
    notify();
  }
  function closeOverlay() {
    state.overlay = null;
    notify();
  }

  // Toast
  function showToast(text, duration = 1800) {
    state.toast = { text, id: uid() };
    notify();
    setTimeout(() => {
      if (state.toast && state.toast.text === text) {
        state.toast = null;
        notify();
      }
    }, duration);
  }

  // ---- Live Training ----
  function startLiveSession(fromAction = null) {
    state.liveSession = {
      id: 'live-' + uid(),
      startTime: Date.now(),
      paused: false,
      pausedAt: 0,
      totalPausedMs: 0,
      currentActionId: fromAction || 'bp',
      currentActionName: state.exercises.find(e => e.id === (fromAction || 'bp'))?.name || '杠铃卧推',
      actions: [],
      hrReadings: [],
      inputReps: '',
      inputWeight: '',
    };
    // Start HR simulation if connected
    if (state.hrm.connected) {
      state._liveHrtimer = setInterval(() => {
        if (state.liveSession && !state.liveSession.paused && state.hrm.connected) {
          const bpm = state.hrm.lastBpm || 120;
          state.liveSession.hrReadings.push(bpm);
          if (state.liveSession.hrReadings.length > 120) state.liveSession.hrReadings.shift();
        }
      }, 2000);
    }
    go('live');
  }

  function getLiveElapsedSec() {
    if (!state.liveSession) return 0;
    const now = state.liveSession.paused
      ? state.liveSession.pausedAt
      : Date.now();
    return Math.floor((now - state.liveSession.startTime - state.liveSession.totalPausedMs) / 1000);
  }

  function getLiveAvgHr() {
    const s = state.liveSession;
    if (!s || s.hrReadings.length === 0) return 0;
    return Math.round(s.hrReadings.reduce((a,b) => a+b, 0) / s.hrReadings.length);
  }

  function getLiveMaxHr() {
    const s = state.liveSession;
    if (!s || s.hrReadings.length === 0) return 0;
    return Math.max(...s.hrReadings);
  }

  function togglePause() {
    if (!state.liveSession) return;
    if (state.liveSession.paused) {
      state.liveSession.totalPausedMs += Date.now() - state.liveSession.pausedAt;
      state.liveSession.paused = false;
      state.liveSession.pausedAt = 0;
    } else {
      state.liveSession.paused = true;
      state.liveSession.pausedAt = Date.now();
    }
    notify();
  }

  function setCurrentAction(actionId) {
    const ex = state.exercises.find(e => e.id === actionId);
    if (!ex) return;
    state.liveSession.currentActionId = actionId;
    state.liveSession.currentActionName = ex.name;
    // Ensure action exists in session
    if (!state.liveSession.actions.find(a => a.id === actionId)) {
      state.liveSession.actions.push({ id: actionId, name: ex.name, sets: [] });
    }
    state.liveSession.inputReps = '';
    state.liveSession.inputWeight = '';
    notify();
  }

  function recordSet(actionId, reps, weight) {
    const s = state.liveSession;
    if (!s) return;
    let action = s.actions.find(a => a.id === actionId);
    const ex = state.exercises.find(e => e.id === actionId);
    if (!action) {
      action = { id: actionId, name: ex?.name || actionId, sets: [] };
      s.actions.push(action);
    }
    action.sets.push({ reps: parseInt(reps), weight: parseFloat(weight) || 0 });
    s.inputReps = '';
    s.inputWeight = '';
    // TTS if enabled
    if (state.voice.ttsEnabled && state.voice.enabled) {
      // visual cue — show toast for TTS
      showToast(`已录入 ${action.name} × ${reps}`, 1500);
    }
    notify();
  }

  function setLiveInput(field, value) {
    if (!state.liveSession) return;
    state.liveSession['input' + field[0].toUpperCase() + field.slice(1)] = value;
    notify();
  }

  function endLiveSession() {
    if (!state.liveSession) return;
    go('summary');
  }

  function saveSession() {
    const s = state.liveSession;
    if (!s) return;
    const duration = getLiveElapsedSec();
    const avgHr = getLiveAvgHr();
    const maxHr = getLiveMaxHr();
    const hasStrength = s.actions.some(a => a.sets.length > 0);
    // 由实际动作运动类型派生 (PRD §4.2.3: 有氧动作计入 cardio)，不写死
    const hasCardio = s.actions.some(a => {
      const ex = state.exercises.find(e => e.id === a.id);
      return ex && ex.cardio;
    });
    let activityType = hasCardio ? 'cardio' : (hasStrength ? 'strength' : 'cardio');
    // TODO: 热量公式当前为占位简化版，正式实现须替换为 PRD §8.3.1 ACSM 心率法
    let calories = 0;
    let calorieSource = 'met';
    if (avgHr > 0 && state.profile.weight && state.profile.age && state.profile.gender) {
      calories = Math.round(duration / 60 * (avgHr > 100 ? 6 : 4));
      calorieSource = 'hr';
    } else if (hasStrength) {
      // MET estimation
      const totalWork = s.actions.reduce((t, a) => t + a.sets.reduce((tt, s) => tt + s.reps * (s.weight || 20) * 0.001, 0), 0);
      calories = Math.round(totalWork * 30 + duration / 60 * 5);
      calorieSource = 'met';
    }
    // Build title
    const firstAction = s.actions.find(a => a.sets.length > 0);
    const title = firstAction ? `${firstAction.name.split('杠铃')[1] || firstAction.name}训练` : '训练';

    // Generate HR curve from readings
    const readings = s.hrReadings;
    const hrCurve = [];
    if (readings.length > 0) {
      const steps = 12;
      for (let i = 0; i < steps; i++) {
        const idx = Math.floor(i * (readings.length - 1) / (steps - 1));
        hrCurve.push(readings[idx]);
      }
    }

    const newRec = {
      id: 'rec-' + uid(),
      date: todayStr(),
      startTime: new Date(s.startTime).toTimeString().slice(0, 5),
      duration,
      dataSource: 'app',
      activityType,
      calories,
      calorieSource,
      avgHr,
      maxHr,
      title,
      actions: s.actions.filter(a => a.sets.length > 0),
      hrCurve,
    };
    state.records.unshift(newRec);
    state.currentRecordId = newRec.id;

    // Cleanup live session
    if (state._liveHrtimer) { clearInterval(state._liveHrtimer); state._liveHrtimer = null; }
    state.liveSession = null;

    go('detail', { recordId: newRec.id });
    showToast('训练已保存', 2000);
  }

  function discardSession() {
    if (state._liveHrtimer) { clearInterval(state._liveHrtimer); state._liveHrtimer = null; }
    state.liveSession = null;
    go('home');
    showToast('训练已放弃', 1500);
  }

  function deleteRecord(id) {
    const idx = state.records.findIndex(r => r.id === id);
    if (idx >= 0) {
      state.records.splice(idx, 1);
    }
    closeOverlay();
    go('records');
    showToast('记录已删除', 1500);
  }

  // ---- Body metrics mutations ----
  function addBodyMetric(metric, value, source = 'manual') {
    const entry = { date: todayStr(), value: parseFloat(value), source };
    if (!state.bodyMetrics[metric]) state.bodyMetrics[metric] = [];
    state.bodyMetrics[metric].unshift(entry);
    closeOverlay();
    notify();
    showToast('已保存', 1500);
    // R9.10: 体重手动录入后，按 PRD 须确认是否同步到个人资料，不在无确认下静默覆盖
    if (metric === 'weight' && source === 'manual') {
      const v = parseFloat(value);
      if (state.profile.weight !== v) {
        state._pendingWeight = v;
        openOverlay({ type: 'dialog', title: '同步到个人资料', content: '将个人资料体重更新为 ' + v + ' kg？', confirmText: '同步', confirmVariant: 'primary', onConfirm: 'JLStore.confirmWeightSync()', cancelText: '暂不' });
      }
    }
  }
  function confirmWeightSync() {
    if (state._pendingWeight != null) {
      state.profile.weight = state._pendingWeight;
      state._pendingWeight = null;
    }
    closeOverlay();
    notify();
    showToast('已同步到个人资料', 1500);
  }

  function deleteBodyMetric(metric, index) {
    if (state.bodyMetrics[metric] && state.bodyMetrics[metric][index]) {
      state.bodyMetrics[metric].splice(index, 1);
      closeOverlay();
      notify();
      showToast('已删除', 1200);
    }
  }

  function togglePeriod() {
    state.profile.periodEnabled = !state.profile.periodEnabled;
    notify();
  }

  // ---- Exercise library ----
  function addCustomExercise(name, category, met) {
    const n = (name || '').trim();
    if (!n) { showToast('请输入动作名称'); return false; }
    // R10.2: 新增动作须与现有动作(含内置)重名校验，避免重复
    const dup = state.exercises.find(e => e.name.trim().toLowerCase() === n.toLowerCase());
    if (dup) { showToast('已存在同名动作：' + dup.name, 2500); return false; }
    const id = 'custom-' + uid();
    state.exercises.push({ id, name: n, category, met: parseFloat(met) || 5.0, custom: true });
    closeOverlay();
    notify();
    showToast('动作已添加', 1500);
    return true;
  }
  function deleteExercise(id) {
    // Check if referenced
    const referenced = state.records.some(r =>
      r.actions.some(a => a.id === id)
    );
    if (referenced) {
      showToast('该动作已被训练记录引用，无法删除', 2500);
      return false;
    }
    const idx = state.exercises.findIndex(e => e.id === id);
    if (idx >= 0) state.exercises.splice(idx, 1);
    closeOverlay();
    notify();
    showToast('动作已删除', 1500);
    return true;
  }
  function getFilteredExercises(search = '') {
    let list = state.exercises;
    if (state.currentExerciseCat !== 'all') {
      list = list.filter(e => e.category === state.currentExerciseCat);
    }
    if (search) {
      const s = search.toLowerCase();
      list = list.filter(e => e.name.toLowerCase().includes(s) || e.id.toLowerCase().includes(s));
    }
    return list;
  }

  // ---- First run / permissions ----
  function grantMicPermission() {
    state.firstRun.micPermissionGranted = true;
    notify();
  }

  // ---- Public API ----
  return {
    // State access
    get state() { return state; },
    subscribe(fn) { subscribers.add(fn); return () => subscribers.delete(fn); },

    // Computed
    getLatest, getBMI, getWeeklyCalories, getWeeklyGoal,
    getFilteredRecords, getLastRecord,
    getLiveElapsedSec, getLiveAvgHr, getLiveMaxHr,
    getFilteredExercises,

    // Profile
    updateProfile,

    // Huawei / sync
    setSyncState, toggleHuaweiConnection, triggerSync, simulateUnauthorized,

    // HRM
    connectHRM, disconnectHRM, scanHRM, startReconnect, setHRMReturnTo, clearHRMReturnTo,

    // Voice
    toggleVoice, setVoiceVolume, toggleVoiceCommand, toggleVoiceTTS,
    startListening, stopListening, processVoiceCommand,

    // Navigation
    go, setMetricTab, setRecordFilter, setExerciseCat,

    // Overlays
    openOverlay, closeOverlay,

    // Toast
    showToast,

    // Live session
    startLiveSession, togglePause, setCurrentAction,
    recordSet, setLiveInput, endLiveSession,
    saveSession, discardSession, deleteRecord,

    // Body metrics
    addBodyMetric, deleteBodyMetric, togglePeriod, confirmWeightSync,

    // Exercises
    addCustomExercise, deleteExercise,

    // Permissions
    grantMicPermission,

    // Helpers
    fmtTime, fmtDurationLong, todayStr, daysAgo,
  };
})();

// Export for module usage; global for inline script
if (typeof module !== 'undefined' && module.exports) module.exports = JLStore;
if (typeof window !== 'undefined') window.JLStore = JLStore;
